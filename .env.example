# Vulcan Configuration
# Copy this file to .env and fill in your API keys

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default LLM provider: claude or openai
VULCAN_LLM_PROVIDER=claude

# Default scan mode: quick, standard, full
VULCAN_SCAN_MODE=standard

# Output directory for scan results and reports
VULCAN_OUTPUT_DIR=./vulcan_output

# Maximum command execution timeout (seconds)
VULCAN_CMD_TIMEOUT=300

# Maximum concurrent tool executions
VULCAN_MAX_CONCURRENCY=5

# Report format: html, pdf, json
VULCAN_REPORT_FORMAT=html
